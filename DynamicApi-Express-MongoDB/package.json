{
  "name": "dynamic-api-express-mongodb",
  "version": "2.0.0",
  "description": "Universal MongoDB Operations API - Execute dynamic operations on any MongoDB collection via REST endpoints. Reference implementation based on DynamicApi-Django.",
  "main": "src/index.js",
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "lint": "eslint src --fix",
    "run:win": "set NODE_ENV=development && node src/index.js"
  },
  "keywords": [
    "api",
    "express",
    "dynamic",
    "mongodb",
    "rest",
    "crud",
    "aggregation",
    "transactions"
  ],
  "author": "Development Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourrepo/dynamic-api"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.6.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "swagger-ui-express": "^4.6.0",
    "swagger-jsdoc": "^6.2.5",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.50.0",
    "supertest": "^6.3.3"
  }
}
