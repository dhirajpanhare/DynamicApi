    {
      "name": "AGGREGATE Operations",
      "item": [
        {
          "name": "Count by Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operationType\": \"aggregate\",\n  \"collectionName\": \"users\",\n  \"parameters\": {\n    \"pipeline\": [\n      { \"$group\": { \"_id\": \"$status\", \"count\": { \"$sum\": 1 } } },\n      { \"$sort\": { \"count\": -1 } }\n    ]\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/v1.0/DynamicApi/Operations",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "v1.0", "DynamicApi", "Operations"]
            }
