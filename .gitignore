# ============================================================================
# ROOT .GITIGNORE FOR DYNAMIC API MONOREPO
# ============================================================================
# This file prevents sensitive data, build artifacts, and dependencies from
# being committed to version control

# ============================================================================
# ENVIRONMENT VARIABLES & SECRETS (CRITICAL - NEVER COMMIT)
# ============================================================================
# Local environment files
.env
.env.local
.env.production
.env.development
.env.test
.env.staging
.env*.local
.env*.private

# Backup environment files
.env.*.backup
.env.*.bak
.env.*.swp

# Configuration files with secrets
DEPLOYMENT_CONFIG.ini
deployment_config.ini
*.ini.local
config.local.ini
secrets.json
.secrets
credentials.json
credentials/
auth/
private-keys/

# Wrangler specific secrets
.wrangler/
wrangler-*.toml
.wrangler-secrets
wrangler.secrets

# Google Cloud specific
.gcloudignore
google-credentials.json
service-account-key.json
service-account-*.json
.gcloud-credentials
.gcloud/
gcloud-*.json

# AWS (if ever used)
.aws/
.aws/**
aws-credentials.json
*.pem
*.key
*.ppk

