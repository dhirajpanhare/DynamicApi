# Root .gitignore for Dynamic API Monorepo

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# Environment Variables
.env
.env.local
.env.*.local

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Build Output
dist/
build/
output/
out/
.build/

# Database (local development only)
*.db
*.sqlite3
*.sqlite3-journal
*.sqlitedb

# Package Manager Lock Files (if versioning package-lock.json separately)
# Uncomment below if you want git to ignore all node lock files
# package-lock.json
# yarn.lock

# Virtual Environments
venv/
env/
ENV/
.venv
__pycache__/
*.py[cod]

# Documentation & Backups
*.bak
*.backup
*.tmp

# Project-specific
docs/node_modules/
