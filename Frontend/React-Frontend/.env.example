# Dynamic API Frontend - Environment Variables Template
# Copy this file to .env.local and update values for your local development

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Select default API backend to use
# Available options:
#   - dotnet-mssql      (.NET + SQL Server)
#   - dotnet-mysql      (.NET + MySQL)
#   - django-mssql      (Django + SQL Server)
#   - django-mysql      (Django + MySQL)
#   - express-mongodb   (Express + MongoDB)
#   - express-mssql     (Express + SQL Server)
#   - express-mysql     (Express + MySQL)
VITE_API_TYPE=dotnet-mssql

# Select which backend to use for OTP email service
# If not set, falls back to VITE_API_TYPE
# This allows you to use ANY of the 7 backends for email, independent of API selection
VITE_EMAIL_BACKEND_TYPE=express-mongodb

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Frontend application URL (used for CORS, redirects, etc.)
# Development: http://localhost:5173 (Vite default)
# Production: https://yourdomain.com
VITE_FRONTEND_URL=http://localhost:5173

# ============================================================================
# BACKEND API ENDPOINTS
# ============================================================================
# Define the base URLs for each backend
# These are used by the API selector to determine health status and routing
# ALL backends support OTP email service (via VITE_EMAIL_BACKEND_TYPE)

# .NET Backend URLs
VITE_DOTNET_MSSQL_URL=http://localhost:5000
VITE_DOTNET_MYSQL_URL=http://localhost:5001

# Django Backend URLs (Python)
VITE_DJANGO_MSSQL_URL=http://localhost:8000
VITE_DJANGO_MYSQL_URL=http://localhost:8001

# Express Backend URLs (Node.js)
VITE_EXPRESS_MONGODB_URL=http://localhost:3001
VITE_EXPRESS_MSSQL_URL=http://localhost:3002
VITE_EXPRESS_MYSQL_URL=http://localhost:3003

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features based on environment

# Enable health check for all APIs
VITE_FEATURE_HEALTH_CHECK=true

# Enable multi-API selector
VITE_FEATURE_MULTI_API_SELECTOR=true

# Enable analytics dashboard
VITE_FEATURE_ANALYTICS=true

# Enable API call history
VITE_FEATURE_API_HISTORY=true

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================

# API request timeout (milliseconds)
# Default: 30000ms (30 seconds)
VITE_API_TIMEOUT=30000

# Maximum number of items to store in history
# Default: 100
VITE_MAX_HISTORY_ITEMS=100

# Cache enabled (localStorage)
VITE_CACHE_ENABLED=true

# Cache expiration time (milliseconds, 0 = no expiration)
VITE_CACHE_EXPIRY=0

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Enable debug mode (verbose logging to console)
# WARNING: Disable in production!
VITE_DEBUG=true

# Log level (error | warn | info | debug)
VITE_LOG_LEVEL=debug

# ============================================================================
# SECURITY
# ============================================================================

# CORS allowed origins (comma-separated)
# Used for security validation
VITE_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200

# Require HTTPS only (set to true in production)
VITE_HTTPS_ONLY=false

# JWT token storage location (localStorage | sessionStorage)
VITE_TOKEN_STORAGE=localStorage

# ============================================================================
# API SETTINGS
# ============================================================================

# API version
VITE_API_VERSION=v1.0

# API prefix/base path
VITE_API_PREFIX=/api

# Retry failed requests
VITE_ENABLE_RETRY=true

# Number of retries for failed requests
VITE_MAX_RETRIES=3
