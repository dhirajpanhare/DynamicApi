# DynamicApi-Express Environment Variables

DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourPassword123!
DB_NAME=DynamicApiDb
DB_ENCRYPT=false
DB_TRUST_SERVER_CERT=true

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-min-32-characters-long
JWT_EXPIRATION=3600

# Logging
LOG_LEVEL=debug
