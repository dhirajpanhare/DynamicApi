# DynamicApi (.NET) Environment

## Database Configuration
ConnectionStrings:DefaultConnection=Server=127.0.0.1;Port=3306;Database=DynamicApiDb;User=root;Password=123456;Charset=utf8mb4;

## JWT Configuration
Jwt:Secret=your-very-secret-key-that-must-be-at-least-32-characters-long-12345
Jwt:Issuer=DynamicApi
Jwt:Audience=DynamicApiUsers
Jwt:ExpirationMinutes=60

## ──────────────────────────────────────────────────────────────────────────
## AUTHENTICATION
## ──────────────────────────────────────────────────────────────────────────
## AUTH_MODE controls the authentication strategy:
##
##   none    — No authentication (default for development)
##   token   — Static token(s) only  → set STATIC_TOKENS below
##   jwt     — JWT only              → set JWT_SECRETS below
##   hybrid  — Both static + JWT     → use during migration
##
AUTH_MODE=none

## Hardcoded static tokens (comma-separated). Clients send: Authorization: Bearer <token>
## Generate: [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
## Remove once all clients switch to JWT.
STATIC_TOKENS=

## JWT secrets from external auth APIs (comma-separated, one per project).
## Dynamic API never generates tokens — it only validates them.
## Your auth API signs tokens with HS256; add that secret here.
JWT_SECRETS=

## External auth service URL (optional — takes priority over AUTH_MODE)
## If set, every token is forwarded to this URL for validation.
## POST with Authorization: Bearer <token>  →  expects { "status": true|false }
## Leave empty to use AUTH_MODE instead.
AUTH_SERVICE_URL=

Logging:LogLevel:Default=Information
Logging:LogLevel:Microsoft=Information

## ──────────────────────────────────────────────────────────────────────────
## EMAIL CONFIGURATION
## ──────────────────────────────────────────────────────────────────────────
## EMAIL_PROVIDER determines which email service to use: GMAIL, MAILGUN, SENDGRID, or SMTP
## Options: GMAIL, MAILGUN, SENDGRID, SMTP, CONSOLE (for development)
## Default: GMAIL
Email:Provider=GMAIL

## GMAIL Configuration
## 1. Enable 2FA on your Google account
## 2. Create an App Password: https://myaccount.google.com/apppasswords
## 3. Use the 16-character app password below (no spaces)
Email:SenderEmail=dhirajpanhare08@gmail.com
Email:GmailUser=dhirajpanhare08@gmail.com
Email:GmailAppPassword=orryxsirlwmwzqon

## MAILGUN Configuration (alternative provider)
Email:MailgunDomain=mg.yourdomain.com
Email:MailgunApiKey=your-mailgun-api-key
Email:MailgunEmail=noreply@mg.yourdomain.com

## SENDGRID Configuration (alternative provider)
Email:SendGridApiKey=your-sendgrid-api-key

## Generic SMTP Configuration (any SMTP provider)
Email:SmtpServer=smtp.gmail.com
Email:SmtpPort=587
Email:SmtpUser=dhirajpanhare08@gmail.com
Email:SmtpPassword=orryxsirlwmwzqon

## ──────────────────────────────────────────────────────────────────────────
## OTP CONFIGURATION
## ──────────────────────────────────────────────────────────────────────────
Otp:Length=6
Otp:ExpiryMinutes=10
Otp:MaxAttempts=5

## Server
ASPNETCORE_URLS=http://0.0.0.0:5000
ASPNETCORE_ENVIRONMENT=Development
