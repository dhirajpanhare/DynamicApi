{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "CorsOrigins": "http://localhost:3000,http://localhost:5173,http://localhost:4200,http://localhost:8000,http://localhost:5000,https://yourdomain.com,https://api.yourdomain.com",
  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST},${DB_PORT};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "yourdomain.com",
    "Audience": "yourdomain-clients",
    "ExpirationMinutes": 60
  }
}
