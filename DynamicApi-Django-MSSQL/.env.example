# ─────────────────────────────────────────────────────────────────────────────
# Dynamic API — Django / MSSQL  •  Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ────────────────────────────────────────────────────────────────
DB_NAME=DynamicApiDb
DB_USER=sa
DB_PASSWORD=YourPassword123!
DB_HOST=127.0.0.1
DB_PORT=1433
DB_DRIVER=ODBC Driver 17 for SQL Server

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Authentication ───────────────────────────────────────────────────────────
# AUTH_SERVICE_URL (optional — takes priority over AUTH_MODE)
# If set, every token is forwarded to this URL for validation.
# POST with Authorization: Bearer <token>  →  expects { "status": true|false }
# Leave empty to use AUTH_MODE instead.
AUTH_SERVICE_URL=

# AUTH_MODE (used when AUTH_SERVICE_URL is not set)
#   none    — No authentication (development / internal networks)
#   token   — Static token(s) via STATIC_TOKENS
#   jwt     — JWT from external auth API(s) via JWT_SECRETS
#   hybrid  — Both static tokens AND JWTs (migration phase)
AUTH_MODE=none

# Hardcoded static tokens (comma-separated). Clients send: Authorization: Bearer <token>
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
STATIC_TOKENS=

# JWT secrets from external auth APIs (comma-separated, one per project).
# Dynamic API never generates tokens — it only validates them.
JWT_SECRETS=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
